<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background matching chest PNG neutral dark gray -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FF252525" />
        </shape>
    </item>

    <!-- Foggy teal radial glow (simulates workout FoggyBackground) -->
    <item android:gravity="center">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="300%"
                android:startColor="#3000B4D4"
                android:centerColor="#1500E5CC"
                android:endColor="#00000000" />
            <size android:width="1200dp" android:height="1200dp" />
        </shape>
    </item>

    <!-- Chest PNG centered -->
    <item>
        <bitmap
            android:gravity="center"
            android:src="@drawable/launch_image" />
    </item>

</layer-list>
